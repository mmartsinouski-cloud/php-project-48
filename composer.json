{
  "authors": [
    {
      "name": "Martsinouski M"
    }
  ],
  "autoload": {
    "psr-4": {
      "Hexlet\\Code\\": "src/"
    },
    "files": [
      "src/Differ.php",
      "src/AstBuilder.php",
      "src/Formatters/Stylish.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Hexlet\\Code\\Tests\\": "tests/"
    }
  },
  "bin": ["bin/gendiff"],
  "license": "MIT",
  "minimum-stability": "stable",
  "name": "hexlet/code",
  "require": {
    "docopt/docopt": "^1.0",
    "symfony/yaml": "^7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "scripts": {
    "test": "phpunit tests",
    "test-coverage": "XDEBUG_MODE=coverage phpunit tests --coverage-clover build/logs/clover.xml",
    "cs-check": "phpcs --standard=PSR12 src tests",
    "cs-fix": "phpcbf --standard=PSR12 src tests"
  },
  "type": "library"
}
